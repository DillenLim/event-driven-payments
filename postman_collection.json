{
    "info": {
        "_postman_id": "event-driven-payments-demo",
        "name": "Event Driven Payments Demo",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Create Payment",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"amount\": 100.00,\n    \"currency\": \"USD\",\n    \"debitorId\": \"user-123\",\n    \"beneficiaryId\": \"merchant-456\"\n}"
                },
                "url": {
                    "raw": "http://localhost:8081/payments",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "8081",
                    "path": [
                        "payments"
                    ]
                }
            },
            "response": []
        },
        {
            "name": "Get Payment Status",
            "request": {
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "http://localhost:8081/payments/{{paymentId}}",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "8081",
                    "path": [
                        "payments",
                        "{{paymentId}}"
                    ]
                }
            },
            "response": []
        }
    ]
}